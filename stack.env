# ── Coinbase Developer Platform credentials ────────────────────────────────────
# Obtain these from https://portal.cdp.coinbase.com → API Keys

# The "id" field from the downloaded CDP API key JSON file
CDP_API_KEY_NAME=YOUR_KEY_ID

# The "privateKey" field from the downloaded CDP API key JSON file (base64, paste as-is)
CDP_API_KEY_PRIVATE_KEY=YOUR_PRIVATE_KEY

# ── Network ────────────────────────────────────────────────────────────────────
# Use base-sepolia for development/testing (free testnet funds via faucet).
# Switch to base-mainnet only when you are ready for real funds.
NETWORK_ID=base-sepolia

# ── Web UI ─────────────────────────────────────────────────────────────────────
# Port the built-in status/monitoring web server listens on.
WEB_PORT=3002

# ── Activity log retention ─────────────────────────────────────────────────────
# Days to retain activity log entries. Older entries are purged on startup.
LOG_RETENTION_DAYS=30

# ── Wallet data storage ────────────────────────────────────────────────────────
# Leave unset to use a Docker-managed named volume (default, recommended).
# Set to an absolute host path to use a bind mount instead — gives full control
# over where wallet_data.json lives and makes backups straightforward.
# The directory must exist and be owned by UID 1000 before starting the container:
#   mkdir -p /opt/coinbase-mcp/data && chown 1000:1000 /opt/coinbase-mcp/data
# WALLET_DATA_PATH=/opt/coinbase-mcp/data
WALLET_DATA_PATH=/home/pi/shared/docker/coinbase/data

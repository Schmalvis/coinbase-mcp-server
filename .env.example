# ── Coinbase Developer Platform credentials ────────────────────────────────────
# Obtain these from https://portal.cdp.coinbase.com → API Keys

# The "Key ID" shown in the CDP portal
CDP_API_KEY_NAME=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID

# The full EC private key (PEM format, newlines replaced with \n)
CDP_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----\n"

# ── CDP v2 credentials (for test-v2-wallet script / future migration) ──────────
# Obtain from https://portal.cdp.coinbase.com → API Keys (select v2)
CDP_API_KEY_ID=your-key-id-here
CDP_API_KEY_SECRET=your-api-key-secret-here
CDP_WALLET_SECRET=your-wallet-secret-here

# ── Network ────────────────────────────────────────────────────────────────────
# Use base-sepolia for development/testing (free testnet funds via faucet).
# Switch to base-mainnet only when you are ready for real funds.
NETWORK_ID=base-sepolia

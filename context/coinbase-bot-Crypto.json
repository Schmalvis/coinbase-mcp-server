    {
      "parameters": {
        "jsCode": "const { generateJwt } = require(\"@coinbase/cdp-sdk/auth\");\n\n  // Generate the JWT using the CDP SDK\n  const token = await generateJwt({\n    apiKeyId: $input.first().json.keyID,\n    apiKeySecret: $input.first().json.keySec,\n    requestMethod: $input.first().json.reqMeth,\n    requestHost: $input.first().json.host,\n    requestPath: $input.first().json.path,\n    expiresIn: $input.first().json.expiry // optional (defaults to 120 seconds)\n  });\n\nconsole.log(token);\n\nreturn[\n  {\n    json: {\n      method: $input.first().json.reqMeth,\n      url: \"https://\" + $input.first().json.host + $input.first().json.path,\n      token: token\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        -352
      ],
      "id": "3a39284b-2548-40ba-834f-41e9a7fd88b3",
      "name": "generateJWT-Bearer"
    },
    {
      "parameters": {
        "jsCode": "const walletSecret=\"your-wallet-secret\"\nconst requestMethod=\"POST\"\nconst requestPath=\"/platform/v2/evm/accounts/0x742d35Cc6634C0532925a3b844Bc454e4438f44e/sign/transaction\"\nconst requestHost=\"api.cdp.coinbase.com\"\nconst requestBody='{\"transaction\": \"0x1234567890123456789012345678901234567890\"}'\n\nconst jose = require('jose');\nconst crypto = require('crypto');\n\n// Create the JWT payload\nconst now = Math.floor(Date.now() / 1000);\nconst uri = `${requestMethod} ${requestHost}${requestPath}`;\n\nconst payload = {\n  iat: now,\n  nbf: now,\n  jti: crypto.randomBytes(16).toString('hex'),\n  uris: [uri]\n};\n\nfunction sortKeys(obj) {\n  if (!obj || typeof obj !== \"object\") {\n    return obj;\n  }\n\n  if (Array.isArray(obj)) {\n    return obj.map(sortKeys);\n  }\n\n  return Object.keys(obj)\n    .sort()\n    .reduce(\n      (acc, key) => {\n        acc[key] = sortKeys(obj[key]);\n        return acc;\n      },\n      {},\n    );\n}\n\n// Add request body if present\nif (requestBody) {\n  const sortedBody = sortKeys(JSON.parse(requestBody));\n  payload.reqHash = crypto\n    .createHash('sha256')\n    .update(Buffer.from(JSON.stringify(sortedBody)))\n    .digest('hex');\n}\n\n// Generate the JWT\nconst getJWT = (async () => {\n  const ecKey = crypto.createPrivateKey({\n    key: walletSecret,\n    format: \"der\",\n    type: \"pkcs8\",\n    encoding: \"base64\",\n  });\n\n  // Sign JWT\n  const jwt = await new jose.SignJWT(payload)\n    .setProtectedHeader({ alg: 'ES256', typ: 'JWT' })\n    .sign(ecKey);\n\n  return jwt;\n})();\n\nreturn[\n  {\n    json: {\n      walletJWT: getJWT()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,

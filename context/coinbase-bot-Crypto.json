    {
      "parameters": {
        "jsCode": "const accounts = $json.accounts || [];\nconst filteredAccounts = accounts.map(account => ({\n  name: account.name,\n  currency: account.currency,\n  availableValue: account.available_balance.value,\n  holdValue: account.hold.value,\n  uuid: account.uuid,\n  portfolioId: account.retail_portfolio_id\n}));\n\nreturn[\n  {\n    json: {\n      filteredAccounts\n    }\n  }\n];"
      },
